{
    "pipeline": {
        "description": "ARM Firmware Analysis Pipeline — TF-A GIC-700 WITH BUGS (differential validation)",
        "stages": [
            {
                "id": "stage1",
                "name": "Source Preprocessing",
                "enabled": true,
                "module": "modules.stage1.preprocessor",
                "class": "Stage1Preprocessor",
                "depends_on": [],
                "params": {
                    "compile_commands": "fw_samples/tf_a_with_bugs/build/compile_commands.json",
                    "compiler": "D:/llvm-mingw/bin/clang.exe",
                    "output_dir": "data/preprocessing/ARM_CORELINK_GIC_700_r4p0_with_bugs"
                }
            },
            {
                "id": "stage2",
                "name": "AST Analysis",
                "enabled": true,
                "module": "modules.stage2.ast_analysis",
                "class": "Stage2ASTAnalysis",
                "depends_on": ["stage1"],
                "params": {
                    "preprocessed_dir": "data/preprocessing/ARM_CORELINK_GIC_700_r4p0_with_bugs",
                    "output_dir": "data/static/ARM_CORELINK_GIC_700_r4p0_with_bugs",
                    "ast_engine": "libclang",
                    "extract": {
                        "functions": true,
                        "globals": true,
                        "types": true,
                        "interrupts": true,
                        "registers": true,
                        "state_machines": true,
                        "interfaces": true,
                        "call_graph": true
                    }
                }
            },
            {
                "id": "stage3",
                "name": "ELF Binary Analysis",
                "enabled": true,
                "module": "modules.stage3.elf_analysis",
                "class": "Stage3ELFBinaryAnalysis",
                "depends_on": ["stage2"],
                "params": {
                    "elf_file": "fw_samples/tf_a_with_bugs/build/gic_harness.elf",
                    "output_dir": "data/binary/ARM_CORELINK_GIC_700_r4p0_with_bugs",
                    "arch": "AARCH64",
                    "static_dir": "data/static/ARM_CORELINK_GIC_700_r4p0_with_bugs",
                    "unified_output_dir": "data/modeling/ARM_CORELINK_GIC_700_r4p0_with_bugs",
                    "extract": {
                        "functions": true,
                        "globals": true,
                        "types": true,
                        "call_graph": true,
                        "unified_graph": true
                    }
                }
            },
            {
                "id": "stage4",
                "name": "Event-Driven Architecture Analysis + Protocol Conformance",
                "enabled": true,
                "module": "modules.stage4.event_analysis",
                "class": "Stage4EventArchAnalysis",
                "depends_on": ["stage2", "stage3"],
                "params": {
                    "ast_output_dir": "data/static/ARM_CORELINK_GIC_700_r4p0_with_bugs",
                    "elf_output_dir": "data/binary/ARM_CORELINK_GIC_700_r4p0_with_bugs",
                    "output_dir": "data/modeling_with_bugs",
                    "spec_model_dir": "D:/programming/spec_model/data/arm_corelink_gic_700_r4p0/extract",
                    "rules_dir": "rules",
                    "checks": {
                        "protocol_conformance": true,
                        "irq_priority": false,
                        "critical_section": false,
                        "stack_analysis": false,
                        "uninit_globals": false,
                        "reentrancy": false,
                        "state_machine_integrity": false
                    }
                }
            },
            {
                "id": "stage5",
                "name": "Dynamic Symbolic Execution",
                "enabled": true,
                "module": "modules.stage5.symbolic_execution",
                "class": "Stage5SymbolicExecution",
                "depends_on": ["stage4"],
                "params": {
                    "elf_file": "fw_samples/tf_a_with_bugs/build/gic_harness.elf",
                    "output_dir": "data/sym_execution",
                    "protocol_name": "ARM_CORELINK_GIC_700",
                    "protocol_version": "r4p0_with_bugs",
                    "spec_model_path": "D:/programming/spec_model/data/arm_corelink_gic_700_r4p0/extract/stage3/latest/manifest.json",
                    "global_strategy": {
                        "default_max_depth": 2,
                        "timeout": 120,
                        "veritesting": true,
                        "default_hook_type": "symbolic_return",
                        "call_graph_path": "data/modeling/ARM_CORELINK_GIC_700_r4p0_with_bugs/call_graph_unified.json"
                    },
                    "hooks": {
                        "__assert_fail": {
                            "hook_type": "concrete_stub",
                            "return_range": [0, 0]
                        }
                    },
                    "inspect_specs": {
                        "gicd_read_ctlr": {
                            "risk_level": "info",
                            "risk_tags": ["register_read"],
                            "description": "GICD_CTLR register read — base protocol operation"
                        },
                        "gicd_write_ctlr": {
                            "risk_level": "warning",
                            "risk_tags": ["register_write"],
                            "description": "GICD_CTLR register write — protocol critical"
                        },
                        "gicd_wait_for_pending_write": {
                            "risk_level": "critical",
                            "risk_tags": ["protocol_compliance", "rwp_poll"],
                            "description": "RWP polling after GICD_CTLR write — MUST be present per GIC spec"
                        }
                    },
                    "entry_points": [
                        {"function": "gicv3_distif_init", "max_depth": 2, "context": "GIC distributor init — GICD_CTLR write sequence"},
                        {"function": "gicv3_driver_init", "max_depth": 2, "context": "GIC driver init — probe + erratas"},
                        {"function": "gicv3_rdistif_init", "max_depth": 2, "context": "GIC redistributor init — per-core"}
                    ]
                }
            },
            {
                "id": "stage6",
                "name": "Risk Audit & Aggregation",
                "enabled": true,
                "module": "modules.stage6.risk_aggregator",
                "class": "Stage6RiskAggregator",
                "depends_on": ["stage4", "stage5"],
                "params": {
                    "protocol_name": "ARM_CORELINK_GIC_700",
                    "protocol_version": "r4p0_with_bugs",
                    "output_dir": "data/risks",
                    "spec_model_dir": "D:/programming/spec_model/data/arm_corelink_gic_700_r4p0/extract",
                    "stage4_pc_path": "data/modeling_with_bugs/ARM_CORELINK_GIC_700_r4p0/protocol_conformance/report.json",
                    "stage5_report_path": "data/sym_execution/ARM_CORELINK_GIC_700_r4p0_with_bugs/symbolic_report.json",
                    "stage5_traces_dir": "data/sym_execution/ARM_CORELINK_GIC_700_r4p0_with_bugs/traces"
                }
            }
        ]
    }
}
