{
  "metadata": {
    "protocol": "DDR5",
    "version": "JESD79-5C",
    "description": "Mock protocol knowledge base for sw_model protocol conformance analysis",
    "status": "concept_prototype"
  },
  "object_entities": {
    "registers": [
      {
        "name": "MR0",
        "address": 0,
        "description": "Burst Length, DLL Control",
        "fields": {
          "BL": {"bits": [0,2], "valid_values": [0, 1, 2], "description": "Burst Length: 0=BL16, 1=BL32, 2=BL64"},
          "DLL_EN": {"bit": 3, "valid_values": [0, 1], "description": "DLL enable"},
          "WR_LAT": {"bits": [4,7], "valid_values": [0, 15], "description": "Write latency"},
          "RD_LAT": {"bits": [8,11], "valid_values": [0, 15], "description": "Read latency"},
          "DQ_BUF_MODE": {"bit": 12, "valid_values": [0, 1], "description": "DQ buffer mode"}
        }
      },
      {
        "name": "MR1",
        "address": 1,
        "description": "Driver Strength, ODT",
        "fields": {
          "RTT_NOM": {"bits": [0,2], "valid_values": [0, 1, 2, 3, 4], "description": "0=HiZ, 1=RZQ/4, 2=RZQ/2, 3=RZQ/6, 4=RZQ/8"},
          "DQ_DRV_STR": {"bits": [3,4], "valid_values": [0, 1, 2, 3], "description": "0=RZQ/6, 1=RZQ/7, 2=RZQ/8, 3=RZQ/10"},
          "CA_DRV_STR": {"bits": [6,7], "valid_values": [0, 1, 2, 3], "description": "Same as DQ drive strength"}
        }
      },
      {
        "name": "MR2",
        "address": 2,
        "description": "Vref Training Control",
        "fields": {
          "VREF_DQ_TRAIN_EN": {"bit": 0, "valid_values": [0, 1]},
          "VREF_CA_TRAIN_EN": {"bit": 1, "valid_values": [0, 1]},
          "VREF_DQ_RANGE": {"bits": [2,3], "valid_values": [0, 1, 2, 3]},
          "VREF_CA_RANGE": {"bits": [4,5], "valid_values": [0, 1, 2, 3]}
        }
      },
      {
        "name": "MR3",
        "address": 3,
        "description": "CRC, Parity, Data Mask",
        "fields": {
          "CRC_EN_WR": {"bit": 0, "valid_values": [0, 1], "depends_on": [], "description": "0=off, 1=on"},
          "CRC_EN_RD": {"bit": 1, "valid_values": [0, 1], "depends_on": []},
          "PARITY_EN": {"bit": 2, "valid_values": [0, 1]},
          "DM_EN": {"bit": 3, "valid_values": [0, 1]}
        },
        "cross_dependency": "MR5_DFE_EN depends on MR3 CRC configuration state"
      },
      {
        "name": "MR4",
        "address": 4,
        "description": "Per-DRAM Addressability",
        "fields": {
          "PDA_EN": {"bit": 0, "valid_values": [0, 1]},
          "CONN_TEST_EN": {"bit": 1, "valid_values": [0, 1]}
        }
      },
      {
        "name": "MR5",
        "address": 5,
        "description": "Read/Write Preamble, DFE",
        "fields": {
          "RD_PREAMBLE": {"bits": [0,1], "valid_values": [0, 1, 2], "description": "0=1tCK, 1=2tCK, 2=off"},
          "WR_PREAMBLE": {"bit": 2, "valid_values": [0, 1], "description": "0=1tCK, 1=2tCK"},
          "DFE_EN": {"bit": 3, "valid_values": [0, 1], "depends_on": ["MR3.CRC_EN_WR=1"], "description": "DFE requires CRC enabled on writes"}
        }
      },
      {
        "name": "MR6",
        "address": 6,
        "description": "Vref DQ Training Value",
        "fields": {
          "VREF_DQ_VAL": {"bits": [0,6], "valid_values": [0, 127], "description": "7-bit Vref code, values >127 are invalid"}
        }
      },
      {
        "name": "MR7",
        "address": 7,
        "description": "Vref CA Training Value",
        "fields": {
          "VREF_CA_VAL": {"bits": [0,6], "valid_values": [0, 127]}
        }
      },
      {
        "name": "MR8",
        "address": 8,
        "description": "DQ Training Pattern A"
      },
      {
        "name": "MR9",
        "address": 9,
        "description": "DQ Training Pattern B"
      },
      {
        "name": "MR10",
        "address": 10,
        "description": "CA Training Pattern"
      },
      {
        "name": "MR11",
        "address": 11,
        "description": "Duty Cycle Adjuster",
        "fields": {
          "DCA_EN": {"bit": 0, "valid_values": [0, 1]},
          "DCA_VAL": {"bits": [1,5], "valid_values": [0, 31], "description": "5-bit duty cycle adjust"}
        }
      },
      {
        "name": "MR21",
        "address": 21,
        "description": "Write CRC Mode",
        "fields": {
          "WCRC": {"bits": [0,1], "valid_values": [0, 1, 2], "description": "0=off, 1=CRC-8, 2=CRC-16"}
        }
      },
      {
        "name": "MR22",
        "address": 22,
        "description": "Read CRC Mode",
        "fields": {
          "RCRC": {"bits": [0,1], "valid_values": [0, 1, 2]}
        }
      }
    ],
    "commands": [
      {"name": "MRW", "opcode": "20", "description": "Mode Register Write"},
      {"name": "MRR", "opcode": "21", "description": "Mode Register Read"},
      {"name": "ZQ_CL", "opcode": "36", "description": "ZQ Calibration Long"},
      {"name": "ZQ_CS", "opcode": "37", "description": "ZQ Calibration Short"},
      {"name": "MPC", "opcode": "38", "description": "Multi-Purpose Command (training entry)"},
      {"name": "ACTIVATE", "opcode": "1", "description": "Bank Activate"},
      {"name": "READ", "opcode": "4", "description": "Read"},
      {"name": "WRITE", "opcode": "8", "description": "Write"}
    ],
    "expected_init_sequence": [
      "RESET_n assert",
      "RESET_n de-assert",
      "CKE high",
      "MRW MR0",
      "MRW MR1",
      "MRW MR2",
      "MRW MR3",
      "MRW MR4",
      "MRW MR5",
      "MRW MR6 (Vref DQ)",
      "MRW MR7 (Vref CA)",
      "ZQ_CL",
      "MRW MR8 (DQ pattern A)",
      "MRW MR9 (DQ pattern B)",
      "MRW MR10 (CA pattern)",
      "MRW MR11 (DCA)",
      "MRW MR21 (CRC write)",
      "MRW MR22 (CRC read)",
      "MRR verify MR0-MR22"
    ]
  },
  "generalized_interfaces": {
    "CA_Bus": {
      "description": "Command/Address bus — 14-bit CA bus encoding",
      "commands": {
        "ACTIVATE": {"ca_pins": "CS_n=0, CA[13:0]=1", "tRCD_min": 40},
        "WRITE": {"ca_pins": "CS_n=0, CA[13:0]=8", "tWR_min": 48},
        "READ": {"ca_pins": "CS_n=0, CA[13:0]=4", "tCL_min": 40},
        "MRW": {"ca_pins": "CS_n=0, CA[13:0]=20", "tMRD_min": 8},
        "MRR": {"ca_pins": "CS_n=0, CA[13:0]=21", "tMRD_min": 8},
        "ZQ_CL": {"ca_pins": "CS_n=0, CA[13:0]=36", "tZQinit_min": 1024},
        "ZQ_CS": {"ca_pins": "CS_n=0, CA[13:0]=37", "tZQoper_min": 512},
        "MPC": {"ca_pins": "CS_n=0, CA[13:0]=38"}
      }
    },
    "MR_Interface": {
      "description": "Mode Register access via controller registers",
      "register_map": {
        "DDR_CTRL_MR_OP":   {"offset": "0", "access": "rw"},
        "DDR_CTRL_MR_ADDR": {"offset": "4", "access": "rw"},
        "DDR_CTRL_MR_DATA": {"offset": "8", "access": "rw"},
        "DDR_CTRL_MR_CMD":  {"offset": "12", "access": "rw", "values": {"MRW": 0, "MRR": 1, "BUSY": "(1<<31)"}}
      }
    }
  },
  "behavior_constraints": {
    "timing": [
      {"parameter": "tRCD",    "min_cycles": 40, "description": "ACT to READ/WRITE", "section": "§5.2.7"},
      {"parameter": "tCL",     "min_cycles": 40, "description": "CAS Latency", "section": "§5.2.1"},
      {"parameter": "tRP",     "min_cycles": 40, "description": "PRECHARGE to ACT", "section": "§5.2.8"},
      {"parameter": "tRAS",    "min_cycles": 84, "description": "ACT to PRECHARGE", "section": "§5.2.9"},
      {"parameter": "tRC",     "min_cycles": 124, "description": "ACT to ACT (same bank)", "section": "§5.2.10"},
      {"parameter": "tMRD",    "min_cycles": 8,  "description": "MRW to MRR/MRW delay", "section": "§5.2.17"},
      {"parameter": "tZQinit", "min_cycles": 1024, "description": "ZQ_CL to NORMAL", "section": "§5.2.18"},
      {"parameter": "tZQoper", "min_cycles": 512, "description": "ZQ_CS to NORMAL", "section": "§5.2.19"},
      {"parameter": "tXPR",    "min_cycles": 512, "description": "CKE high to first valid cmd after reset", "section": "§5.2.20"},
      {"parameter": "tDLLK",   "min_cycles": 1024, "description": "DLL lock time", "section": "§5.2.21"},
      {"parameter": "tWR",     "min_cycles": 48,  "description": "WRITE to PRECHARGE", "section": "§5.2.12"},
      {"parameter": "tRFC",    "min_cycles": 560, "description": "REFRESH cycle", "section": "§5.2.16"}
    ],
    "state_machines": [
      {
        "name": "ddr5_init",
        "description": "DDR5 initialization state machine per JESD79-5C §3.3",
        "protocol_states": 12,
        "expected_states": [
          "DDR5_STATE_RESET",
          "DDR5_STATE_CKE_HIGH",
          "DDR5_STATE_MR_CONFIG",
          "DDR5_STATE_VREF_TRAIN",
          "DDR5_STATE_ZQ_CALIB",
          "DDR5_STATE_DQ_TRAIN",
          "DDR5_STATE_CA_TRAIN",
          "DDR5_STATE_DCA_TRAIN",
          "DDR5_STATE_CRC_CONFIG",
          "DDR5_STATE_MR_VERIFY",
          "DDR5_STATE_READY",
          "DDR5_STATE_ERROR"
        ],
        "expected_transitions": [
          {"from": "DDR5_STATE_RESET", "to": "DDR5_STATE_CKE_HIGH"},
          {"from": "DDR5_STATE_CKE_HIGH", "to": "DDR5_STATE_MR_CONFIG"},
          {"from": "DDR5_STATE_MR_CONFIG", "to": "DDR5_STATE_VREF_TRAIN"},
          {"from": "DDR5_STATE_VREF_TRAIN", "to": "DDR5_STATE_ZQ_CALIB"},
          {"from": "DDR5_STATE_ZQ_CALIB", "to": "DDR5_STATE_DQ_TRAIN"},
          {"from": "DDR5_STATE_DQ_TRAIN", "to": "DDR5_STATE_CA_TRAIN"},
          {"from": "DDR5_STATE_CA_TRAIN", "to": "DDR5_STATE_DCA_TRAIN"},
          {"from": "DDR5_STATE_DCA_TRAIN", "to": "DDR5_STATE_CRC_CONFIG"},
          {"from": "DDR5_STATE_CRC_CONFIG", "to": "DDR5_STATE_MR_VERIFY"},
          {"from": "DDR5_STATE_MR_VERIFY", "to": "DDR5_STATE_READY"},
          {"from": "*", "to": "DDR5_STATE_ERROR", "description": "Any state can transition to ERROR on failure"}
        ],
        "error_recovery_required": true,
        "recovery_requirement": "ERROR state must have a defined recovery path (retry or graceful degradation), not just a dead-end"
      }
    ]
  },
  "scenarios": {
    "initialization": {
      "name": "DDR5 Power-Up Initialization",
      "trigger_event": "SoC power-on reset complete",
      "reference": "JESD79-5C §3.3",
      "expected_path": [
        {"step": 1, "action": "Assert RESET_n low", "state": "RESET"},
        {"step": 2, "action": "Stabilize VDD/VDDQ", "state": "RESET"},
        {"step": 3, "action": "De-assert RESET_n, wait tXPR", "state": "CKE_HIGH", "timing": "tXPR=512"},
        {"step": 4, "action": "Set CKE high, wait tDLLK", "state": "CKE_HIGH", "timing": "tDLLK=1024"},
        {"step": 5, "action": "Configure MR0-MR5", "state": "MR_CONFIG"},
        {"step": 6, "action": "Conduct Vref training (MR6-MR7)", "state": "VREF_TRAIN"},
        {"step": 7, "action": "ZQ calibration (tZQinit)", "state": "ZQ_CALIB", "timing": "tZQinit=1024"},
        {"step": 8, "action": "DQ training (MR8-MR9 + write leveling)", "state": "DQ_TRAIN"},
        {"step": 9, "action": "CA training (MR10)", "state": "CA_TRAIN"},
        {"step": 10, "action": "DCA training (MR11)", "state": "DCA_TRAIN"},
        {"step": 11, "action": "Configure CRC (MR21-MR22)", "state": "CRC_CONFIG"},
        {"step": 12, "action": "MRR verify all configured registers", "state": "MR_VERIFY"},
        {"step": 13, "action": "Enter normal operation", "state": "READY"}
      ],
      "timing_requirements": {
        "MRW_to_MRW": {"min_cycles": 8, "parameter": "tMRD"},
        "MRW_to_MRR": {"min_cycles": 8, "parameter": "tMRD"},
        "ZQ_CL_to_NORMAL": {"min_cycles": 1024, "parameter": "tZQinit"},
        "CKE_to_first_cmd": {"min_cycles": 512, "parameter": "tXPR"}
      }
    }
  }
}