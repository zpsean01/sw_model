{
    "pipeline": {
        "description": "ARM Firmware Analysis Pipeline — TF-A GIC-700 MVP target",
        "stages": [
            {
                "id": "stage1",
                "name": "Source Preprocessing",
                "enabled": true,
                "module": "modules.stage1.preprocessor",
                "class": "Stage1Preprocessor",
                "depends_on": [],
                "params": {
                    "compile_commands": "fw_samples/tf_a/build/compile_commands.json",
                    "compiler": "D:/llvm-mingw/bin/clang.exe",
                    "output_dir": "data/preprocessing"
                }
            },
            {
                "id": "stage2",
                "name": "AST Analysis",
                "enabled": true,
                "module": "modules.stage2.ast_analysis",
                "class": "Stage2ASTAnalysis",
                "depends_on": ["stage1"],
                "params": {
                    "preprocessed_dir": "data/preprocessing",
                    "output_dir": "data/static",
                    "ast_engine": "libclang",
                    "extract": {
                        "functions": true,
                        "globals": true,
                        "types": true,
                        "interrupts": true,
                        "registers": true,
                        "state_machines": true,
                        "interfaces": true,
                        "call_graph": true
                    }
                }
            },
            {
                "id": "stage3",
                "name": "ELF Binary Analysis",
                "enabled": false,
                "module": "modules.stage3.elf_analysis",
                "class": "Stage3ELFBinaryAnalysis",
                "depends_on": [],
                "params": {
                    "elf_file": "",
                    "output_dir": "data/binary",
                    "arch": "ARM"
                }
            },
            {
                "id": "stage4",
                "name": "Event-Driven Architecture Analysis",
                "enabled": true,
                "module": "modules.stage4.event_analysis",
                "class": "Stage4EventArchAnalysis",
                "depends_on": ["stage2"],
                "params": {
                    "ast_output_dir": "data/static",
                    "elf_output_dir": "data/binary",
                    "output_dir": "data/modeling",
                    "spec_model_path": "",
                    "spec_model_dir": "D:/programming/spec_model/data/arm_corelink_gic_700_r4p0/extract",
                    "rules_dir": "rules",
                    "checks": {
                        "irq_priority": true,
                        "critical_section": true,
                        "stack_analysis": true,
                        "uninit_globals": true,
                        "reentrancy": true,
                        "state_machine_integrity": true,
                        "protocol_conformance": true
                    }
                }
            },
            {
                "id": "stage5",
                "name": "Dynamic Symbolic Execution",
                "enabled": false,
                "module": "modules.stage5.symbolic_execution",
                "class": "Stage5SymbolicExecution",
                "depends_on": ["stage4"],
                "params": {}
            },
            {
                "id": "stage6",
                "name": "Risk Audit & Aggregation",
                "enabled": true,
                "module": "modules.stage6.risk_aggregator",
                "class": "Stage6RiskAggregator",
                "depends_on": ["stage4"],
                "params": {
                    "protocol_name": "ARM_CORELINK_GIC_700",
                    "protocol_version": "r4p0",
                    "output_dir": "data/risks",
                    "spec_model_path": "D:/programming/spec_model/data/arm_corelink_gic_700_r4p0/extract/stage3/latest/behavior_space_graph.json",
                    "stage4_pc_path": "data/modeling/protocol_conformance/report.json",
                    "stage5_report_path": "",
                    "stage5_traces_dir": ""
                }
            }
        ]
    }
}
