{
    "pipeline": {
        "description": "ARM Firmware Analysis Pipeline Configuration",
        "stages": [
            {
                "id": "stage1",
                "name": "Source Preprocessing",
                "enabled": true,
                "module": "modules.stage1.preprocessor",
                "class": "Stage1Preprocessor",
                "depends_on": [],
                "params": {
                    "compile_commands": "fw_samples/build/compile_commands.json",
                    "compiler": "D:/llvm-mingw/bin/clang.exe",
                    "output_dir": "data/preprocessing"
                }
            },
            {
                "id": "stage2",
                "name": "AST Analysis",
                "enabled": true,
                "module": "modules.stage2.ast_analysis",
                "class": "Stage2ASTAnalysis",
                "depends_on": ["stage1"],
                "params": {
                    "preprocessed_dir": "data/preprocessing",
                    "output_dir": "data/static",
                    "ast_engine": "libclang",
                    "extract": {
                        "functions": true,
                        "globals": true,
                        "types": true,
                        "interrupts": true,
                        "registers": true,
                        "state_machines": true,
                        "interfaces": true,
                        "call_graph": true
                    }
                }
            },
            {
                "id": "stage3",
                "name": "ELF Binary Analysis",
                "enabled": true,
                "module": "modules.stage3.elf_analysis",
                "class": "Stage3ELFBinaryAnalysis",
                "depends_on": [],
                "params": {
                    "elf_file": "fw_samples/build/bin/firmware_tfm.elf",
                    "output_dir": "data/binary",
                    "arch": "ARM",
                    "extract": {
                        "functions": true,
                        "globals": true,
                        "types": true,
                        "call_graph": true
                    }
                }
            },
            {
                "id": "stage4",
                "name": "Event-Driven Architecture Analysis",
                "enabled": true,
                "module": "modules.stage4.event_analysis",
                "class": "Stage4EventArchAnalysis",
                "depends_on": ["stage2", "stage3"],
                "params": {
                    "ast_output_dir": "data/static",
                    "elf_output_dir": "data/binary",
                    "output_dir": "data/modeling",
                    "spec_model_path": "data/spec_model_ddr5_mock.json",
                    "checks": {
                        "irq_priority": true,
                        "critical_section": true,
                        "stack_analysis": true,
                        "uninit_globals": true,
                        "reentrancy": true,
                        "state_machine_integrity": true,
                        "protocol_conformance": true
                    }
                }
            },
            {
                "id": "stage5",
                "name": "Dynamic Symbolic Execution",
                "enabled": true,
                "module": "modules.stage5.symbolic_execution",
                "class": "Stage5SymbolicExecution",
                "depends_on": ["stage4"],
                "params": {
                    "elf_file": "fw_samples/build/bin/firmware_tfm.elf",
                    "output_dir": "data/sym_execution",
                    "target_addresses": [],
                    "exploration": {
                        "timeout": 300,
                        "max_depth": 100,
                        "veritesting": true,
                        "lazy_initialization": true
                    }
                }
            }
        ]
    }
}