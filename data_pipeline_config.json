{
    "pipeline": {
        "description": "ARM Firmware Analysis Pipeline Configuration",
        "stages": [
            {
                "id": "stage1",
                "name": "Source Preprocessing",
                "enabled": true,
                "module": "modules.stage1.preprocessor",
                "class": "Stage1Preprocessor",
                "depends_on": [],
                "params": {
                    "compile_commands": "fw_samples/build/compile_commands.json",
                    "compiler": "D:/llvm-mingw/bin/clang.exe",
                    "output_dir": "data/preprocessing"
                }
            },
            {
                "id": "stage2",
                "name": "AST Analysis",
                "enabled": true,
                "module": "modules.stage2.ast_analysis",
                "class": "Stage2ASTAnalysis",
                "depends_on": ["stage1"],
                "params": {
                    "preprocessed_dir": "data/preprocessing",
                    "output_dir": "data/static",
                    "ast_engine": "libclang",
                    "extract": {
                        "functions": true,
                        "globals": true,
                        "types": true,
                        "interrupts": true,
                        "registers": true,
                        "state_machines": true,
                        "interfaces": true,
                        "call_graph": true
                    }
                }
            },
            {
                "id": "stage3",
                "name": "ELF Binary Analysis",
                "enabled": true,
                "module": "modules.stage3.elf_analysis",
                "class": "Stage3ELFBinaryAnalysis",
                "depends_on": [],
                "params": {
                    "elf_file": "fw_samples/build/bin/firmware_tfm.elf",
                    "output_dir": "data/binary",
                    "arch": "ARM",
                    "extract": {
                        "functions": true,
                        "globals": true,
                        "types": true,
                        "call_graph": true
                    }
                }
            },
            {
                "id": "stage4",
                "name": "Event-Driven Architecture Analysis",
                "enabled": true,
                "module": "modules.stage4.event_analysis",
                "class": "Stage4EventArchAnalysis",
                "depends_on": ["stage2", "stage3"],
                "params": {
                    "ast_output_dir": "data/static",
                    "elf_output_dir": "data/binary",
                    "output_dir": "data/modeling",
                    "spec_model_path": "data/spec_model_ddr5_mock.json",
                    "checks": {
                        "irq_priority": true,
                        "critical_section": true,
                        "stack_analysis": true,
                        "uninit_globals": true,
                        "reentrancy": true,
                        "state_machine_integrity": true,
                        "protocol_conformance": true
                    }
                }
            },
            {
                "id": "stage5",
                "name": "Dynamic Symbolic Execution (Depth-Limited)",
                "enabled": true,
                "module": "modules.stage5.symbolic_execution",
                "class": "Stage5SymbolicExecution",
                "depends_on": ["stage4"],
                "params": {
                    "elf_file": "fw_samples/build/bin/firmware_tfm.elf",
                    "output_dir": "data/sym_execution",
                    "spec_model_path": "data/spec_model_ddr5_mock.json",

                    "entry_points": [],

                    "global_strategy": {
                        "call_graph_path": "data/modeling/call_graph_unified.json",
                        "default_max_depth": 3,
                        "timeout": 300,
                        "veritesting": true
                    },

                    "hooks": {
                        "ddr5_train_vref_dq": {
                            "hook_type": "symbolic_return"
                        },
                        "ddr5_train_vref_ca": {
                            "hook_type": "symbolic_return"
                        },
                        "ddr5_write_reg": {
                            "hook_type": "symbolic_return"
                        }
                    },

                    "inspect_specs": {
                        "ddr5_train_vref_dq": {
                            "risk_level": "warning",
                            "risk_tags": ["register_write", "value_range_overflow"],
                            "return_range": [0, 255],
                            "description": "Writes MR6 VREF_DQ_VAL. Returns 0-255 but spec limits to 0-127 (7-bit)."
                        },
                        "ddr5_train_vref_ca": {
                            "risk_level": "warning",
                            "risk_tags": ["register_write", "value_range_overflow"],
                            "return_range": [0, 255],
                            "description": "Writes MR7 VREF_CA_VAL. Returns 0-255 but spec limits to 0-127 (7-bit)."
                        },
                        "ddr5_write_reg": {
                            "risk_level": "warning",
                            "risk_tags": ["register_write", "timing_critical"],
                            "description": "Writes a mode register. tMRD timing must be observed after this call."
                        }
                    }
                }
            },
            {
                "id": "stage6",
                "name": "Risk Audit & Aggregation",
                "enabled": true,
                "module": "modules.stage6.risk_aggregator",
                "class": "Stage6RiskAggregator",
                "depends_on": ["stage4", "stage5"],
                "params": {
                    "output_dir": "data/risks",
                    "spec_model_path": "data/spec_model_ddr5_mock.json",
                    "stage4_pc_path": "data/modeling/DDR5_JESD79-5C/protocol_conformance/report.json",
                    "stage5_report_path": "data/sym_execution/symbolic_report.json",
                    "stage5_traces_dir": "data/sym_execution/traces"
                }
            }
        ]
    }
}